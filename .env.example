# SelfMind / mello-android — environment template
#
# Copy to `.env` for local development:
#   cp .env.example .env
# Then fill in the real values from 1Password / EAS Secrets / the team
# secrets vault. NEVER commit a populated `.env` file.
#
# For preview & production builds, every value below MUST exist as an
# EAS Secret — non-sensitive ones can also live in `eas.json`'s `env`
# block. Don't paste real keys into eas.json.

# ─── Hume AI EVI ─────────────────────────────────────────────────────────────
# Get keys: https://app.hume.ai/keys | Create EVI config: https://app.hume.ai/evi
HUME_API_KEY=your_hume_api_key_here
HUME_CONFIG_ID=your_hume_config_id_here

# ─── LiveKit (Hindi voice via webapp server) ────────────────────────────────
LIVEKIT_API_URL=https://your-token-server.example.com/api/livekit-token

# ─── AWS Bedrock ────────────────────────────────────────────────────────────
# Default model is Claude Haiku 4.5 (uses AWS_BEARER_TOKEN_BEDROCK).
# Llama 3 8B is the fallback path (uses AWS_ACCESS_KEY_ID / SECRET via SigV4).
# Switch in services/chat/bedrockService.ts → FALLBACK_TO_LLAMA.

AWS_BEDROCK_REGION=us-east-1

# Llama (fallback) model id
AWS_BEDROCK_MODEL_ARN=meta.llama3-8b-instruct-v1:0

# Claude Haiku 4.5 inference profile (US cross-region)
AWS_BEDROCK_HAIKU_MODEL_ID=us.anthropic.claude-haiku-4-5-20251001-v1:0

# IAM credentials — required ONLY when FALLBACK_TO_LLAMA = true
AWS_ACCESS_KEY_ID=your_aws_access_key_id_here
AWS_SECRET_ACCESS_KEY=your_aws_secret_access_key_here

# Bedrock long-term API key — required when FALLBACK_TO_LLAMA = false (default)
# Format: ABSK...
AWS_BEARER_TOKEN_BEDROCK=your_bedrock_long_term_api_key_here
