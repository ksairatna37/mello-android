{
  "expo": {
    "name": "SelfMind",
    "slug": "mello",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/selfmind-app-icon-padded.png",
    "scheme": "selfmind",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "ios": {
      "buildNumber": "1",
      "supportsTablet": false,
      "bundleIdentifier": "health.melloai.app",
      "infoPlist": {
        "NSMicrophoneUsageDescription": "SelfMind needs microphone access for voice conversations.",
        "NSSpeechRecognitionUsageDescription": "SelfMind uses speech recognition to understand you better.",
        "UIBackgroundModes": ["audio"],
        "CFBundleURLTypes": [
          {
            "CFBundleURLSchemes": [
              "com.googleusercontent.apps.499732705533-ot31akqnmvgvona2a89j2dbhfle7a2om"
            ]
          },
          {
            "CFBundleURLSchemes": [
              "com.googleusercontent.apps.499732705533-ot31akqnmvgvona2a89j2dbhfle7a2om"
            ]
          }
        ],
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/selfmind-adaptive-foreground.png",
        "backgroundColor": "#FAF6EE"
      },
      "package": "health.melloai.app",
      "permissions": [
        "RECORD_AUDIO",
        "android.permission.RECORD_AUDIO",
        "android.permission.MODIFY_AUDIO_SETTINGS",
        "android.permission.POST_NOTIFICATIONS"
      ],
      "edgeToEdgeEnabled": true,
      "softwareKeyboardLayoutMode": "pan"
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro"
    },
    "plugins": [
      "./plugins/with-android-light-theme",
      "expo-router",
      "expo-secure-store",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#FAF6EE",
          "image": "./assets/selfmind-splash-v2.png",
          "imageWidth": 240,
          "resizeMode": "contain",
          "ios": {
            "image": "./assets/selfmind-splash-v2.png",
            "imageWidth": 160,
            "backgroundColor": "#FAF6EE",
            "resizeMode": "contain"
          },
          "android": {
            "image": "./assets/selfmind-splash-v2.png",
            "imageWidth": 240,
            "backgroundColor": "#FAF6EE",
            "resizeMode": "contain"
          }
        }
      ],
      [
        "expo-av",
        {
          "microphonePermission": "SelfMind needs microphone access for voice conversations."
        }
      ],
      [
        "expo-audio",
        {
          "microphonePermission": "SelfMind needs microphone access for voice conversations."
        }
      ],
      [
        "expo-speech-recognition",
        {
          "microphonePermission": "SelfMind needs microphone access for voice conversations.",
          "speechRecognitionPermission": "SelfMind uses speech recognition to understand you better."
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/icon.png",
          "color": "#FF6B35"
        }
      ],
      "expo-web-browser",
      "@react-native-google-signin/google-signin"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "841494e5-4e32-47f3-a891-9373d197e851"
      }
    }
  }
}
